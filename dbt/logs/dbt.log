  create  table "sqlpad"."gold_"."fact_sessions__dbt_tmp"
  
  
    as
  
  (
    SELECT
    MD5(CONCAT(ts::TEXT, sessionId::TEXT))  AS session_id,
    ts,
    sessionId,
