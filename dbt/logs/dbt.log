    MD5(CONCAT(ts::TEXT, sessionId::TEXT)),
    ts,
    sessionId,
    userId,
    MD5(CONCAT(city, state, zip)),
    level,
    success,
    itemInSession
FROM raw.status_change_events
  );
  
